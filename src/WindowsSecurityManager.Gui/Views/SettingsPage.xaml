<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsSecurityManager.Gui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:WindowsSecurityManager.Gui.ViewModels">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="32,32,32,16">
        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE713;" FontSize="32" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Security Settings" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Toolbar: search, category filter, profile, bulk actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,16,0,16">
            <AutoSuggestBox x:Name="SearchBox" PlaceholderText="Search settings..."
                            QueryIcon="Find" Width="250" TextChanged="SearchBox_TextChanged" />

            <ComboBox x:Name="CategoryFilter" PlaceholderText="All Categories" Width="200"
                      SelectionChanged="CategoryFilter_SelectionChanged" />

            <Button Content="Clear Filter" Click="ClearFilter_Click" />

            <AppBarSeparator />

            <ComboBox x:Name="ProfileCombo" PlaceholderText="Apply Profile..." Width="200"
                      DisplayMemberPath="Name" SelectionChanged="ProfileCombo_SelectionChanged" />

            <AppBarSeparator />

            <Button Content="Enable All" Click="EnableAll_Click" />
            <Button Content="Disable All" Click="DisableAll_Click" />
        </StackPanel>

        <!-- Settings list -->
        <ListView x:Name="SettingsList" Grid.Row="2" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:SettingItemViewModel">
                    <Border Padding="12,8" Margin="0,2">
                        <Grid ColumnDefinitions="80,*,Auto">
                            <!-- Status indicator -->
                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <TextBlock Text="{x:Bind StatusText}" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <!-- Setting info -->
                            <StackPanel Grid.Column="1" Margin="12,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Id}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind Description}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" MaxLines="1" />
                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="Current: " /><Run Text="{x:Bind CurrentValue}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="Expected: " /><Run Text="{x:Bind ExpectedValue}" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Content="Enable" Tag="{x:Bind Id}" Click="Enable_Click"
                                        Style="{StaticResource AccentButtonStyle}" Padding="12,6" />
                                <Button Content="Disable" Tag="{x:Bind Id}" Click="Disable_Click"
                                        Padding="12,6" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <InfoBar x:Name="StatusBar" Grid.Row="3" IsOpen="False" Severity="Success" />
    </Grid>
</Page>
