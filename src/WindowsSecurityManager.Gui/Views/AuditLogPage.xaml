<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsSecurityManager.Gui.Views.AuditLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,Auto,*" Padding="32">
        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE7BA;" FontSize="32" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Audit Log" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,16,0,16">
            <Button Content="Refresh" Click="Refresh_Click" Style="{StaticResource AccentButtonStyle}" />
            <TextBlock x:Name="CountText" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Log entries -->
        <ListView x:Name="LogList" Grid.Row="2" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="160,100,150,*" Padding="4,6">
                        <TextBlock Text="{Binding TimestampDisplay}" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding Action}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="{Binding Target}"
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Grid.Column="3" Text="{Binding Details}" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
