<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsSecurityManager.Gui.Views.ReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="32">
        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE9D9;" FontSize="32" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Compliance Reports" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,16,0,16">
            <ComboBox x:Name="CategoryFilter" PlaceholderText="All Categories" Width="200"
                      SelectionChanged="CategoryFilter_SelectionChanged">
                <x:String>All Categories</x:String>
            </ComboBox>

            <Button Content="Generate Report" Click="Generate_Click" Style="{StaticResource AccentButtonStyle}" />

            <AppBarSeparator />

            <ComboBox x:Name="FormatCombo" SelectedIndex="2" Width="120">
                <x:String>JSON</x:String>
                <x:String>CSV</x:String>
                <x:String>HTML</x:String>
            </ComboBox>

            <Button Content="Export" Click="Export_Click" />
        </StackPanel>

        <!-- Report content -->
        <ScrollViewer Grid.Row="2">
            <StackPanel x:Name="ReportContent" Spacing="16" Visibility="Collapsed">
                <!-- Summary -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="TotalText" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Hardened" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="HardenedText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="Green" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Misconfigured" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="MisconfiguredText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="Orange" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Compliance" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ComplianceText" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Settings detail list -->
                <ListView x:Name="ReportList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="80,60,*,120,120" Padding="4">
                                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{Binding Id}" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                <TextBlock Grid.Column="2" Text="{Binding Name}" Margin="8,0" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" Text="{Binding CurrentDisplay}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="4" Text="{Binding ExpectedDisplay}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <InfoBar x:Name="StatusBar" Grid.Row="3" IsOpen="False" Severity="Informational" />
    </Grid>
</Page>
