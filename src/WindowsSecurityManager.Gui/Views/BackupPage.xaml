<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsSecurityManager.Gui.Views.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto" Padding="32">
        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <FontIcon Glyph="&#xE74E;" FontSize="32" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Backup &amp; Restore" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="24" Margin="0,24,0,0">
            <!-- Backup section -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Create Backup" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Save current registry values for all managed security settings to a JSON file."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox x:Name="BackupCategoryFilter" PlaceholderText="All Categories" Width="200">
                            <x:String>All Categories</x:String>
                        </ComboBox>
                        <Button Content="Create Backup" Click="CreateBackup_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Restore section -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Restore from Backup" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Restore security settings from a previously saved backup file. Only settings matching known definitions will be restored."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBox x:Name="RestorePathBox" PlaceholderText="Path to backup file..." Width="400" />
                        <Button Content="Restore" Click="Restore_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Status bar -->
        <InfoBar x:Name="StatusBar" Grid.Row="2" IsOpen="False" Severity="Informational" />
    </Grid>
</Page>
